<header class="header">
  <nav class="navbar">
    <div class="navbar-brand">
      <a class="navbar-item navbar-logo" href="https://www.redhat.com" target="_blank" rel="noopener noreferrer" title="Red Hat">
        <img src="{{uiRootPath}}/img/logo-redhat.svg" alt="Red Hat" class="navbar-logo-img" width="140" height="33">
      </a>
      <div class="workshop-brand-text">
        <a class="navbar-item site-title" href="{{{relativize 'index.html'}}}">{{site.title}}</a>
      </div>
    </div>
    <div id="topbar-nav" class="navbar-menu">
      <div class="navbar-end">
        <div class="navbar-item workshop-navbar-links">
          <div class="workshop-navbar-lab">
            <a id="link-console" href="https://console-openshift-console.%HUB_DOMAIN%" target="_blank" rel="noopener noreferrer" class="workshop-quick-link" title="OpenShift Console">
              <i class="fa fa-cube"></i><span class="workshop-link-label">Console</span>
            </a>
            <a id="link-developer-hub" href="https://developer-hub.%HUB_DOMAIN%" target="_blank" rel="noopener noreferrer" class="workshop-quick-link" title="Developer Hub">
              <i class="fa fa-th-large"></i><span class="workshop-link-label">Dev Hub</span>
            </a>
            <a id="link-gitea" href="https://gitlab.%HUB_DOMAIN%" target="_blank" rel="noopener noreferrer" class="workshop-quick-link" title="GitLab">
              <i class="fa fa-gitlab"></i><span class="workshop-link-label">GitLab</span>
            </a>
            <a id="link-openshift-ai" href="https://rhods-dashboard-redhat-ods-applications.%HUB_DOMAIN%" target="_blank" rel="noopener noreferrer" class="workshop-quick-link" title="OpenShift AI dashboard">
              <i class="fa fa-magic"></i><span class="workshop-link-label">OCP AI</span>
            </a>
            <button type="button" id="workshop-terminal-toggle" class="workshop-quick-link workshop-terminal-toggle" title="Integrated oc terminal — reconnects automatically when switching browser tabs" aria-expanded="false" aria-controls="workshop-terminal-panel">
              <i class="fa fa-terminal"></i><span class="workshop-link-label">Terminal</span>
            </button>
          </div>
          <div class="workshop-navbar-identity">
            <a id="workshop-register-link" href="https://developer-hub.%HUB_DOMAIN%" class="workshop-quick-link workshop-quick-link--register" title="Log in to Developer Hub">
              <i class="fa fa-id-badge"></i><span class="workshop-link-label">Login</span>
            </a>
            <span id="user-badge" class="workshop-user-badge-nav" style="display:none;">
              <i class="fa fa-user"></i>
              <span id="user-badge-name"></span>
              <button type="button" id="vars-edit-btn" title="Change lab user" class="workshop-user-badge-edit" aria-label="Change lab user">
                <i class="fa fa-pencil"></i>
              </button>
            </span>
            <div id="vars-edit-panel" class="workshop-vars-edit" style="display:none;">
              <label for="user-name-input">User:</label>
              <input type="text" id="user-name-input" placeholder="user1">
              <button type="button" id="vars-save">Save</button>
              <button type="button" id="vars-cancel-edit">Cancel</button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </nav>
</header>
